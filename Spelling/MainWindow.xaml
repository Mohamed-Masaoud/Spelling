<Window x:Class="Spelling.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/Resources/Icon.ico"
        Title="Spelling"
        Height="700"
        Width="950">
    <Window.InputBindings>

        <KeyBinding Key="F1"
                Command="{Binding SpellingVM.Read}" />

        <KeyBinding Key="F2"
                Command="{Binding SpellingVM.Check}" />

        <KeyBinding Key="F3"
                Command="{Binding SpellingVM.Reveal}" />

        <KeyBinding Key="F4"
                Command="{Binding SpellingVM.Next}" />

    </Window.InputBindings>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="1.2*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="16" Margin="0,0,0,12" BorderBrush="#D9DEE7"
            BorderThickness="1">
            <TextBlock Text="Spelling" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"
                Foreground="#1F2937" />
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,12" BorderBrush="#D9DEE7"
            BorderThickness="1" DataContext="{Binding SpellingVM}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Section title -->
                <TextBlock Grid.Row="0" Text="Spelling Practice" FontSize="20" FontWeight="Bold" Foreground="#1F2937" />


                <!-- User input -->
                <TextBox Grid.Row="2" Height="40" FontSize="16" Padding="12,6" VerticalContentAlignment="Center"
                    Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" Background="White" BorderBrush="#D1D5DB"
                    BorderThickness="1" />

                <!-- Buttons -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">

                    <Button Content="Read (F1)" Width="100" Height="36" Margin="6" Command="{Binding Read}"
                        Background="#2563EB" Foreground="White" BorderBrush="#2563EB" FontWeight="SemiBold" />

                    <Button Content="Check (F2)" Width="100" Height="36" Margin="6" Command="{Binding Check}"
                        Background="#10B981" Foreground="White" BorderBrush="#10B981" FontWeight="SemiBold" />

                    <Button Content="Reveal (F3)" Width="100" Height="36" Margin="6" Command="{Binding Reveal}"
                        Background="#F59E0B" Foreground="White" BorderBrush="#F59E0B" FontWeight="SemiBold" />

                    <Button Content="Next (F4)" Width="100" Height="36" Margin="6" Command="{Binding Next}"
                        Background="#6B7280" Foreground="White" BorderBrush="#6B7280" FontWeight="SemiBold" />
                </StackPanel>

                <!-- Feedback message -->
                <TextBlock Grid.Row="5" Text="{Binding Message}" FontSize="15" FontWeight="SemiBold"
                    Foreground="#1F2937" TextWrapping="Wrap" HorizontalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Dictionary section -->
        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="16" BorderBrush="#D9DEE7"
            BorderThickness="1">

            <Grid DataContext="{Binding DictionaryVM}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBlock Grid.Row="0" Text="Dictionary" FontSize="20" FontWeight="Bold" Foreground="#1F2937" />

                <!-- Search -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="100" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" Height="36" Padding="10,6" FontSize="14" VerticalContentAlignment="Center"
                        Text="{Binding SearchWord, UpdateSourceTrigger=PropertyChanged}" />

                    <Button Grid.Column="2" Height="36" Content="Search" Command="{Binding Search}" IsDefault="True"
                        Background="#2563EB" Foreground="White" BorderBrush="#2563EB" FontWeight="SemiBold" />

                    <Button Grid.Column="4" Height="36" Content="Clear" Command="{Binding Clear}" Background="#E5E7EB"
                        Foreground="#111827" BorderBrush="#D1D5DB" FontWeight="SemiBold" />
                </Grid>

                <Grid Grid.Row="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding ErrorMessage}" Foreground="#DC2626" FontWeight="Medium"
                        TextWrapping="Wrap" />

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Definitions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1"
                                        CornerRadius="8" Padding="14" Margin="0,0,0,12">
                                        <StackPanel>

                                            <TextBlock Text="{Binding Word}" FontSize="22" FontWeight="Bold"
                                                Foreground="#111827" Margin="0,0,0,10" />


                                            <Button Content="▶" HorizontalAlignment="Left" Width="28" Height="28"
                                                Margin="0,0,0,10"
                                                Command="{Binding DataContext.DictionaryVM.PlayPhoneticAudio, RelativeSource={RelativeSource AncestorType=Window}}" />
                                            <ItemsControl ItemsSource="{Binding Phonetics}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Text}" FontSize="13"
                                                            FontStyle="Italic" Foreground="#6B7280" Margin="0,0,0,4" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <ItemsControl ItemsSource="{Binding Meanings}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="White" CornerRadius="6" Padding="10"
                                                            Margin="0,8,0,0" BorderBrush="#E5E7EB" BorderThickness="1">
                                                            <StackPanel>

                                                                <TextBlock Text="{Binding partOfSpeech}" FontSize="14"
                                                                    FontWeight="SemiBold" FontStyle="Italic"
                                                                    Foreground="#2563EB" Margin="0,0,0,8" />

                                                                <ItemsControl ItemsSource="{Binding Definitions}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <StackPanel Margin="0,0,0,10">
                                                                                <TextBlock TextWrapping="Wrap"
                                                                                    Foreground="#1F2937" FontSize="14">
                                                                                    <Run Text="• " />
                                                                                    <Run Text="{Binding Text}" />
                                                                                </TextBlock>

                                                                                <TextBlock Text="{Binding Example}"
                                                                                    TextWrapping="Wrap"
                                                                                    Margin="16,4,0,0" FontSize="13"
                                                                                    Foreground="#6B7280"
                                                                                    FontStyle="Italic" />
                                                                            </StackPanel>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>

                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
