<Window x:Class="Spelling.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Spelling"
        mc:Ignorable="d"
        Title="Spelling"
        Height="700"
        Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1.2*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="10"
                Padding="16"
                Margin="0,0,0,12"
                BorderBrush="#D9DEE7"
                BorderThickness="1">
            <TextBlock Text="Spelling"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="#1F2937"/>
        </Border>

        <!-- Keep this row for the spelling section -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="10"
                Padding="16"
                Margin="0,0,0,12"
                BorderBrush="#D9DEE7"
                BorderThickness="1">
            <Grid>
                <TextBlock Text="Spelling section goes here"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#6B7280"/>
            </Grid>
        </Border>

        <!-- Dictionary section -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="10"
                Padding="16"
                BorderBrush="#D9DEE7"
                BorderThickness="1">

            <Grid DataContext="{Binding DictionaryVM}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBlock Grid.Row="0"
                           Text="Dictionary"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#1F2937"/>

                <!-- Search -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Height="36"
                             Padding="10,6"
                             FontSize="14"
                             VerticalContentAlignment="Center"
                             Text="{Binding SearchWord, UpdateSourceTrigger=PropertyChanged}"/>

                    <Button Grid.Column="2"
                            Height="36"
                            Content="Search"
                            Command="{Binding Search}"
                            IsDefault="True"
                            Background="#2563EB"
                            Foreground="White"
                            BorderBrush="#2563EB"
                            FontWeight="SemiBold"/>

                    <Button Grid.Column="4"
                            Height="36"
                            Content="Clear"
                            Command="{Binding Clear}"
                            Background="#E5E7EB"
                            Foreground="#111827"
                            BorderBrush="#D1D5DB"
                            FontWeight="SemiBold"/>
                </Grid>

                <Grid Grid.Row="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{Binding ErrorMessage}"
                               Foreground="#DC2626"
                               FontWeight="Medium"
                               TextWrapping="Wrap"/>

                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Definitions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F9FAFB"
                                            BorderBrush="#E5E7EB"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="14"
                                            Margin="0,0,0,12">
                                        <StackPanel>

                                            <TextBlock Text="{Binding Word}"
                                                       FontSize="22"
                                                       FontWeight="Bold"
                                                       Foreground="#111827"
                                                       Margin="0,0,0,10"/>

                                            
                                            <Button Content="▶" HorizontalAlignment="Left" 
                                                    Width="28"
                                                    Height="28"
                                                    Margin="0,0,0,10"
                                                    Command="{Binding DataContext.DictionaryVM.PlayPhoneticAudio, RelativeSource={RelativeSource AncestorType=Window}}" />
                                            <ItemsControl ItemsSource="{Binding Phonetics}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Text}"
                                                                   FontSize="13"
                                                                   FontStyle="Italic"
                                                                   Foreground="#6B7280"
                                                                   Margin="0,0,0,4"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <ItemsControl ItemsSource="{Binding Meanings}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="White"
                                                                CornerRadius="6"
                                                                Padding="10"
                                                                Margin="0,8,0,0"
                                                                BorderBrush="#E5E7EB"
                                                                BorderThickness="1">
                                                            <StackPanel>

                                                                <TextBlock Text="{Binding partOfSpeech}"
                                                                           FontSize="14"
                                                                           FontWeight="SemiBold"
                                                                           FontStyle="Italic"
                                                                           Foreground="#2563EB"
                                                                           Margin="0,0,0,8"/>

                                                                <ItemsControl ItemsSource="{Binding Definitions}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <StackPanel Margin="0,0,0,10">
                                                                                <TextBlock TextWrapping="Wrap"
                                                                                           Foreground="#1F2937"
                                                                                           FontSize="14">
                                                                                    <Run Text="• "/>
                                                                                    <Run Text="{Binding Text}"/>
                                                                                </TextBlock>

                                                                                <TextBlock Text="{Binding Example}"
                                                                                           TextWrapping="Wrap"
                                                                                           Margin="16,4,0,0"
                                                                                           FontSize="13"
                                                                                           Foreground="#6B7280"
                                                                                           FontStyle="Italic"/>
                                                                            </StackPanel>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>

                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>